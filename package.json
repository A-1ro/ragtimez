{
  "name": "ai-tech-daily",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "node -e \"const fs=require('fs');const p='dist/server/wrangler.json';const c=JSON.parse(fs.readFileSync(p,'utf8'));if(c.assets)delete c.assets.binding;c.ai_search=[];fs.writeFileSync(p,JSON.stringify(c));\"",
    "preview": "astro preview",
    "pages:dev": "wrangler pages dev",
    "astro": "astro",
    "setup:ai-search": "tsx scripts/setup-ai-search.ts",
    "generate:article": "tsx scripts/generate-article.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.6",
    "@astrojs/rss": "^4.0.18",
    "astro": "^6.1.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.14.4"
  }
}
