name = "ai-tech-daily"
pages_build_output_dir = "./dist"
compatibility_date = "2025-04-07"
compatibility_flags = ["nodejs_compat"]

# Workers AI binding – used for LLM / embedding calls from Pages Functions
[ai]
binding = "AI"

# Cloudflare AI Search binding – enables querying the crawl index from Workers
[[ai_search]]
binding = "AI_SEARCH"
instance_name = "ai-tech-daily-search"
