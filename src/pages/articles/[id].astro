---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { trustLabelMap } from "../../constants/trustLevels";
import { formatDate } from "../../utils/date";

// Dynamic route: disable prerendering so the page is rendered on each request
// at the Cloudflare Worker edge, enabling server-side article lookup by ID.
export const prerender = false;

const { id } = Astro.params;

const allArticles = await getCollection("articles");
const article = allArticles.find((a) => a.id === id);

if (!article) {
  return Astro.redirect("/404");
}

const { Content } = await render(article);

const trust = trustLabelMap[article.data.trustLevel];
const user = Astro.locals.user ?? null;
---

<BaseLayout
  title={`${article.data.title} | RAGtimeZ`}
  description={article.data.summary}
  ogType="article"
>
  <article class="article">
    <header class="article-header">
      <a href="/" class="back-link">← 一覧に戻る</a>
      <div class="article-meta">
        <time datetime={article.data.date.toISOString()} class="article-date">
          {formatDate(article.data.date)}
        </time>
        <span
          class="trust-badge"
          style={`background-color: ${trust.color}22; color: ${trust.color}; border-color: ${trust.color}44;`}
        >
          {trust.label}
        </span>
      </div>
      <h1 class="article-title">{article.data.title}</h1>
      <p class="article-summary">{article.data.summary}</p>
      {article.data.tags.length > 0 && (
        <ul class="tag-list" aria-label="タグ">
          {article.data.tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )}
    </header>

    <div class="article-body prose">
      <Content />
    </div>

    {article.data.sources.length > 0 && (
      <aside class="sources">
        <h2 class="sources-heading">出典</h2>
        <ul class="sources-list">
          {article.data.sources.map((source) => (
            <li class="source-item">
              <a href={source.url} target="_blank" rel="noopener noreferrer" class="source-link">
                {source.title ?? source.url}
              </a>
              {source.type && (
                <span class="source-type">{source.type}</span>
              )}
            </li>
          ))}
        </ul>
      </aside>
    )}

    <section class="community-notes" data-article-id={article.id} data-current-github-id={user?.githubId ?? ""}>
      <h2 class="notes-heading">コミュニティノート</h2>

      <div id="notes-list" class="notes-list" aria-live="polite" aria-label="コミュニティノート一覧">
        <div class="loading-state">読み込み中…</div>
      </div>

      {user ? (
        <div class="note-form-container">
          <div class="form-header">
            <img
              src={user.avatarUrl}
              alt={user.login}
              class="form-avatar"
            />
            <span class="form-username">{user.login}</span>
          </div>
          <form id="note-form" class="note-form">
            <textarea
              id="note-textarea"
              name="body"
              placeholder="この記事についての注釈を追加…"
              rows="3"
              maxlength="1000"
              required
            ></textarea>
            <div class="form-footer">
              <span id="char-count" class="char-count">0 / 1000</span>
              <button type="submit" class="submit-button">投稿する</button>
            </div>
          </form>
        </div>
      ) : (
        <div class="login-prompt">
          <p>注釈を追加するにはGitHubにログインしてください。</p>
          <a href="/api/auth/login" class="login-button">GitHubでログイン</a>
        </div>
      )}
    </section>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.5rem 0 3rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }
  .back-link:hover {
    color: var(--color-accent-hover);
    text-decoration: none;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .article-date {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .trust-badge {
    display: inline-block;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid;
    white-space: nowrap;
  }

  .article-title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .article-summary {
    margin: 0 0 1rem;
    font-size: 1.0625rem;
    color: var(--color-muted);
    line-height: 1.6;
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
  }

  .tag-list {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    background: var(--color-border);
    color: var(--color-muted);
    padding: 0.15em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
  }

  /* Article body prose styles */
  .prose {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
    margin-bottom: 2rem;
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 1.5rem 0 0.5rem;
    color: var(--color-text);
  }

  .prose :global(p) {
    margin: 0 0 1rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.375rem;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .prose :global(a) {
    color: var(--color-accent);
  }
  .prose :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .prose :global(code) {
    background: var(--color-border);
    padding: 0.1em 0.35em;
    border-radius: 0.25em;
    font-size: 0.875em;
    font-family: "Fira Code", "Cascadia Code", Consolas, monospace;
  }

  .prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-border);
    margin: 0 0 1rem;
    padding-left: 1rem;
    color: var(--color-muted);
  }

  /* Sources section */
  .sources {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
  }

  .sources-heading {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .sources-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .source-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .source-link {
    font-size: 0.9375rem;
    word-break: break-all;
  }

  .source-type {
    font-size: 0.75rem;
    color: var(--color-muted);
    background: var(--color-border);
    padding: 0.1em 0.5em;
    border-radius: 999px;
    text-transform: capitalize;
  }

  /* Community notes section */
  .community-notes {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .notes-heading {
    margin: 0 0 1.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
    min-height: 60px;
  }

  .loading-state,
  .empty-state {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--color-muted);
    font-style: italic;
  }

  :global(.note-item) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  :global(.note-avatar) {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
  }

  :global(.note-content) {
    flex: 1;
    min-width: 0;
  }

  :global(.note-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  :global(.note-meta) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  :global(.note-username) {
    font-weight: 600;
    color: var(--color-text);
  }

  :global(.note-date) {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  :global(.note-delete-btn) {
    background: none;
    border: none;
    padding: 0.375rem;
    color: var(--color-muted);
    cursor: pointer;
    border-radius: 0.25rem;
    transition: background 0.15s ease, color 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0.5;
  }

  :global(.note-item:hover .note-delete-btn) {
    opacity: 1;
  }

  :global(.note-delete-btn:hover) {
    background: rgba(239, 68, 68, 0.12);
    color: #ef4444;
  }

  :global(.note-body) {
    color: var(--color-text);
    line-height: 1.6;
    word-wrap: break-word;
    white-space: pre-wrap;
  }

  /* Note form container */
  .note-form-container {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
  }

  .form-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .form-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
  }

  .form-username {
    font-weight: 600;
    color: var(--color-text);
  }

  .note-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .note-form textarea {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.75rem;
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.9375rem;
    line-height: 1.5;
    resize: vertical;
    min-height: 100px;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .note-form textarea:focus {
    outline: none;
    background: var(--color-surface);
    border-color: var(--color-accent);
  }

  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .char-count {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .submit-button {
    background: var(--color-accent);
    color: var(--color-text);
    border: none;
    padding: 0.5rem 1.25rem;
    border-radius: 0.375rem;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .submit-button:hover {
    background: var(--color-accent-hover);
  }

  .submit-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .submit-button.loading {
    opacity: 0.7;
    pointer-events: none;
  }

  /* Login prompt */
  .login-prompt {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1.5rem;
    text-align: center;
  }

  .login-prompt p {
    margin: 0 0 1rem;
    color: var(--color-muted);
  }

  .login-button {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-text);
    padding: 0.625rem 1.5rem;
    border-radius: 0.375rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .login-button:hover {
    background: var(--color-accent-hover);
  }

  .error-message {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    margin-bottom: 1rem;
  }

  @media (max-width: 600px) {
    .article {
      padding: 1rem 0 2rem;
    }
    .article-title {
      font-size: 1.375rem;
    }
    .sources {
      padding: 1rem;
    }

    .community-notes {
      margin-top: 2rem;
      padding-top: 1.5rem;
    }

    .notes-heading {
      font-size: 1.125rem;
      margin-bottom: 1rem;
    }

    :global(.note-item) {
      padding: 0.75rem;
      gap: 0.5rem;
    }

    :global(.note-avatar) {
      width: 32px;
      height: 32px;
    }

    :global(.note-header) {
      flex-direction: column;
      align-items: flex-start;
    }

    :global(.note-delete-btn) {
      align-self: flex-end;
    }

    .note-form-container {
      padding: 0.75rem;
    }

    .form-header {
      margin-bottom: 0.75rem;
    }

    .form-footer {
      flex-direction: column;
      align-items: stretch;
    }

    .char-count {
      text-align: right;
    }

    .submit-button {
      width: 100%;
    }

    .login-prompt {
      padding: 1rem;
    }

    .login-button {
      display: block;
      width: 100%;
      padding: 0.75rem;
    }
  }
</style>

<script>
  // Types for community notes
  interface Note {
    id: string;
    article_slug: string;
    author_github_id: string;
    author_username: string;
    author_avatar: string | null;
    body: string;
    created_at: string;
    updated_at: string;
  }

  // Get data attributes from the section
  const section = document.querySelector(".community-notes") as HTMLElement;
  const articleId = section?.getAttribute("data-article-id") ?? "";
  const currentGithubId = section?.getAttribute("data-current-github-id") ?? "";

  const notesList = document.getElementById("notes-list") as HTMLDivElement;
  const noteForm = document.getElementById("note-form") as HTMLFormElement;
  const noteTextarea = document.getElementById("note-textarea") as HTMLTextAreaElement;
  const charCount = document.getElementById("char-count") as HTMLSpanElement;

  // Format relative time (e.g., "2時間前")
  function formatRelativeTime(dateStr: string): string {
    const now = new Date();
    const date = new Date(dateStr);
    const seconds = Math.floor((now.getTime() - date.getTime()) / 1000);

    if (seconds < 60) return "たった今";
    if (seconds < 3600) return `${Math.floor(seconds / 60)}分前`;
    if (seconds < 86400) return `${Math.floor(seconds / 3600)}時間前`;
    if (seconds < 2592000) return `${Math.floor(seconds / 86400)}日前`;

    return date.toLocaleDateString("ja-JP");
  }

  // Render a single note
  function renderNote(note: Note): HTMLElement {
    const div = document.createElement("div");
    div.className = "note-item";
    div.setAttribute("data-note-id", note.id);

    const avatarHtml =
      note.author_avatar && note.author_avatar.trim()
        ? `<img src="${escapeHtml(note.author_avatar)}" alt="${escapeHtml(note.author_username)}" class="note-avatar" width="36" height="36" />`
        : `<div class="note-avatar" style="background: var(--color-border); display: flex; align-items: center; justify-content: center; font-weight: 600;">?</div>`;

    const deleteButtonHtml =
      currentGithubId === note.author_github_id
        ? `<button type="button" class="note-delete-btn" data-note-id="${escapeHtml(note.id)}" aria-label="注釈を削除" title="削除">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="3,6 5,6 21,6"/>
              <path d="M19,6l-1,14a2,2,0,0,1-2,2H8a2,2,0,0,1-2-2L5,6"/>
              <path d="M10,11v6"/><path d="M14,11v6"/>
              <path d="M9,6V4a1,1,0,0,1,1-1h4a1,1,0,0,1,1,1V6"/>
            </svg>
          </button>`
        : "";

    div.innerHTML = `
      ${avatarHtml}
      <div class="note-content">
        <div class="note-header">
          <div class="note-meta">
            <span class="note-username">${escapeHtml(note.author_username)}</span>
            <span class="note-date">${formatRelativeTime(note.created_at)}</span>
          </div>
          ${deleteButtonHtml}
        </div>
        <div class="note-body">${escapeHtml(note.body)}</div>
      </div>
    `;

    // Attach delete handler
    const deleteBtn = div.querySelector(".note-delete-btn") as HTMLButtonElement;
    if (deleteBtn) {
      deleteBtn.addEventListener("click", async () => {
        await deleteNote(note.id, div);
      });
    }

    return div;
  }

  // Simple HTML escape to prevent XSS
  function escapeHtml(text: string): string {
    const map: Record<string, string> = {
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#039;",
    };
    return text.replace(/[&<>"']/g, (char) => map[char]);
  }

  // Load and render notes from the API
  async function loadNotes(): Promise<void> {
    try {
      const response = await fetch(`/api/notes?article=${encodeURIComponent(articleId)}`);

      if (!response.ok) {
        throw new Error(`Failed to load notes: ${response.status}`);
      }

      const data = (await response.json()) as { notes: Note[] };
      const notes = data.notes || [];

      notesList.innerHTML = "";

      if (notes.length === 0) {
        const emptyDiv = document.createElement("div");
        emptyDiv.className = "empty-state";
        emptyDiv.textContent = "まだ注釈はありません。最初の注釈を追加しましょう。";
        notesList.appendChild(emptyDiv);
      } else {
        // Sort by created_at descending (newest first)
        notes.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
        notes.forEach((note) => {
          notesList.appendChild(renderNote(note));
        });
      }
    } catch (error) {
      console.error("Error loading notes:", error);
      notesList.innerHTML = '<div class="empty-state">注釈の読み込みに失敗しました。</div>';
    }
  }

  // Delete a note
  async function deleteNote(noteId: string, noteElement: HTMLElement): Promise<void> {
    if (!confirm("この注釈を削除しますか？")) {
      return;
    }

    try {
      const response = await fetch(`/api/notes/${encodeURIComponent(noteId)}`, {
        method: "DELETE",
      });

      if (!response.ok) {
        throw new Error(`Failed to delete note: ${response.status}`);
      }

      // Remove from DOM with a smooth transition
      noteElement.style.opacity = "0";
      noteElement.style.transition = "opacity 0.2s ease";
      setTimeout(() => {
        noteElement.remove();

        // If no notes left, show empty state
        const remainingNotes = notesList.querySelectorAll(".note-item");
        if (remainingNotes.length === 0) {
          const emptyDiv = document.createElement("div");
          emptyDiv.className = "empty-state";
          emptyDiv.textContent = "まだ注釈はありません。最初の注釈を追加しましょう。";
          notesList.appendChild(emptyDiv);
        }
      }, 200);
    } catch (error) {
      console.error("Error deleting note:", error);
      alert("注釈の削除に失敗しました。");
    }
  }

  // Character count update
  if (noteTextarea) {
    noteTextarea.addEventListener("input", () => {
      const length = noteTextarea.value.length;
      charCount.textContent = `${length} / 1000`;
    });
  }

  // Handle form submission
  if (noteForm) {
    noteForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const body = noteTextarea.value.trim();

      if (!body) {
        alert("注釈を入力してください。");
        return;
      }

      const submitBtn = noteForm.querySelector(".submit-button") as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.classList.add("loading");
      submitBtn.textContent = "投稿中…";

      try {
        const response = await fetch("/api/notes", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            article_slug: articleId,
            body,
          }),
        });

        if (!response.ok) {
          const error = await response.text();
          throw new Error(`Failed to post note: ${response.status} ${error}`);
        }

        const data = (await response.json()) as { note: Note };
        const newNote = data.note;

        // Clear the form
        noteTextarea.value = "";
        charCount.textContent = "0 / 1000";

        // Remove empty state if present
        const emptyState = notesList.querySelector(".empty-state");
        if (emptyState) {
          emptyState.remove();
        }

        // Add new note to the top of the list
        const noteElement = renderNote(newNote);
        noteElement.style.opacity = "0";
        noteElement.style.transition = "opacity 0.3s ease";
        notesList.insertBefore(noteElement, notesList.firstChild);

        // Trigger animation
        setTimeout(() => {
          noteElement.style.opacity = "1";
        }, 10);
      } catch (error) {
        console.error("Error posting note:", error);
        alert("注釈の投稿に失敗しました。");
      } finally {
        submitBtn.disabled = false;
        submitBtn.classList.remove("loading");
        submitBtn.textContent = "投稿する";
      }
    });
  }

  // Load notes on page load
  loadNotes();
</script>
