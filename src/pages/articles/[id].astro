---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { trustLabelMap } from "../../constants/trustLevels";
import { formatDate } from "../../utils/date";

// Dynamic route: disable prerendering so the page is rendered on each request
// at the Cloudflare Worker edge, enabling server-side article lookup by ID.
export const prerender = false;

const { id } = Astro.params;

const allArticles = await getCollection("articles");
const article = allArticles.find((a) => a.id === id);

if (!article) {
  return Astro.redirect("/404");
}

const { Content } = await render(article);

const trust = trustLabelMap[article.data.trustLevel];
---

<BaseLayout
  title={`${article.data.title} | AI Tech Daily`}
  description={article.data.summary}
  ogType="article"
>
  <article class="article">
    <header class="article-header">
      <a href="/" class="back-link">← 一覧に戻る</a>
      <div class="article-meta">
        <time datetime={article.data.date.toISOString()} class="article-date">
          {formatDate(article.data.date)}
        </time>
        <span
          class="trust-badge"
          style={`background-color: ${trust.color}22; color: ${trust.color}; border-color: ${trust.color}44;`}
        >
          {trust.label}
        </span>
      </div>
      <h1 class="article-title">{article.data.title}</h1>
      <p class="article-summary">{article.data.summary}</p>
      {article.data.tags.length > 0 && (
        <ul class="tag-list" aria-label="タグ">
          {article.data.tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )}
    </header>

    <div class="article-body prose">
      <Content />
    </div>

    {article.data.sources.length > 0 && (
      <aside class="sources">
        <h2 class="sources-heading">出典</h2>
        <ul class="sources-list">
          {article.data.sources.map((source) => (
            <li class="source-item">
              <a href={source.url} target="_blank" rel="noopener noreferrer" class="source-link">
                {source.title ?? source.url}
              </a>
              {source.type && (
                <span class="source-type">{source.type}</span>
              )}
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.5rem 0 3rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }
  .back-link:hover {
    color: var(--color-accent-hover);
    text-decoration: none;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .article-date {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .trust-badge {
    display: inline-block;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid;
    white-space: nowrap;
  }

  .article-title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .article-summary {
    margin: 0 0 1rem;
    font-size: 1.0625rem;
    color: var(--color-muted);
    line-height: 1.6;
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
  }

  .tag-list {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    background: var(--color-border);
    color: var(--color-muted);
    padding: 0.15em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
  }

  /* Article body prose styles */
  .prose {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
    margin-bottom: 2rem;
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 1.5rem 0 0.5rem;
    color: var(--color-text);
  }

  .prose :global(p) {
    margin: 0 0 1rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.375rem;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .prose :global(a) {
    color: var(--color-accent);
  }
  .prose :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .prose :global(code) {
    background: var(--color-border);
    padding: 0.1em 0.35em;
    border-radius: 0.25em;
    font-size: 0.875em;
    font-family: "Fira Code", "Cascadia Code", Consolas, monospace;
  }

  .prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-border);
    margin: 0 0 1rem;
    padding-left: 1rem;
    color: var(--color-muted);
  }

  /* Sources section */
  .sources {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
  }

  .sources-heading {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .sources-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .source-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .source-link {
    font-size: 0.9375rem;
    word-break: break-all;
  }

  .source-type {
    font-size: 0.75rem;
    color: var(--color-muted);
    background: var(--color-border);
    padding: 0.1em 0.5em;
    border-radius: 999px;
    text-transform: capitalize;
  }

  @media (max-width: 600px) {
    .article {
      padding: 1rem 0 2rem;
    }
    .article-title {
      font-size: 1.375rem;
    }
    .sources {
      padding: 1rem;
    }
  }
</style>
