---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getContributorBadge } from "../../lib/contributorBadge";
import { env } from "cloudflare:workers";

export const prerender = false;

const { username } = Astro.params;

if (!username) {
  return Astro.redirect("/404");
}

if (!env.DB) {
  return Astro.redirect("/404");
}

// ---------------------------------------------------------------------------
// Fetch user + note_count from D1 (server-side, no self-fetch)
// ---------------------------------------------------------------------------
interface UserRow {
  github_id: string;
  username: string;
  avatar_url: string | null;
  github_url: string | null;
  x_url: string | null;
  linkedin_url: string | null;
  bio: string | null;
  created_at: string;
  note_count: number;
}

interface RecentNoteRow {
  id: string;
  article_slug: string;
  body: string;
  created_at: string;
}

let userRow: UserRow | null = null;
let recentNotes: RecentNoteRow[] = [];

try {
  userRow = await env.DB.prepare(
    `SELECT u.github_id, u.username, u.avatar_url, u.github_url, u.x_url,
            u.linkedin_url, u.bio, u.created_at,
            COALESCE(c.cnt, 0) AS note_count
     FROM users u
     LEFT JOIN (
       SELECT author_github_id, COUNT(*) AS cnt
       FROM notes
       GROUP BY author_github_id
     ) c ON c.author_github_id = u.github_id
     WHERE LOWER(u.username) = LOWER(?)`
  )
    .bind(username)
    .first<UserRow>();

  if (userRow) {
    const notesResult = await env.DB.prepare(
      `SELECT id, article_slug, body, created_at
       FROM notes
       WHERE author_github_id = ?
       ORDER BY created_at DESC
       LIMIT 10`
    )
      .bind(userRow.github_id)
      .all<RecentNoteRow>();

    recentNotes = notesResult.results ?? [];
  }
} catch {
  return Astro.redirect("/404");
}

if (!userRow) {
  return Astro.redirect("/404");
}

// ---------------------------------------------------------------------------
// Resolve article titles for recent notes
// ---------------------------------------------------------------------------
const allArticles = await getCollection("articles");
const articleTitleMap = new Map(allArticles.map((a) => [a.id, a.data.title]));

// ---------------------------------------------------------------------------
// Badge + viewer
// ---------------------------------------------------------------------------
const badge = getContributorBadge(userRow.note_count);
const currentUser = Astro.locals.user ?? null;
const isOwner = currentUser?.githubId === userRow.github_id;

// ---------------------------------------------------------------------------
// Format date (YYYY/M/D) — same style as existing date utilities
// ---------------------------------------------------------------------------
function formatJpDate(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getFullYear()}/${d.getMonth() + 1}/${d.getDate()}`;
}
---

<BaseLayout
  title={`${userRow.username} | RAGtimeZ`}
  description={userRow.bio ?? `${userRow.username} のコントリビュータープロフィール`}
>
  <div class="profile-page">

    <!-- Profile card -->
    <section class="profile-card" aria-labelledby="profile-heading">
      <div class="profile-avatar-wrap">
        {userRow.avatar_url
          ? <img src={userRow.avatar_url} alt={userRow.username} class="profile-avatar" width="96" height="96" />
          : <div class="profile-avatar profile-avatar--fallback" aria-hidden="true">?</div>
        }
      </div>

      <div class="profile-info">
        <h1 id="profile-heading" class="profile-username">{userRow.username}</h1>

        <div class="profile-meta">
          {badge && (
            <span
              class="contributor-badge"
              style={`background-color: ${badge.color}22; color: ${badge.color}; border-color: ${badge.color}44;`}
              title={`${userRow.note_count} 件のノート`}
            >
              {badge.label}
            </span>
          )}
          <span class="profile-note-count">
            {userRow.note_count} 件のノート
          </span>
          <span class="profile-joined">
            参加: {formatJpDate(userRow.created_at)}
          </span>
        </div>

        {userRow.bio && (
          <p class="profile-bio">{userRow.bio}</p>
        )}

        <!-- Social links -->
        <div class="profile-links">
          {userRow.github_url && (
            <a href={userRow.github_url} target="_blank" rel="noopener noreferrer" class="profile-link" aria-label="GitHub">
              <!-- GitHub icon -->
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              GitHub
            </a>
          )}
          {userRow.x_url && (
            <a href={userRow.x_url} target="_blank" rel="noopener noreferrer" class="profile-link" aria-label="X (Twitter)">
              <!-- X icon -->
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              X
            </a>
          )}
          {userRow.linkedin_url && (
            <a href={userRow.linkedin_url} target="_blank" rel="noopener noreferrer" class="profile-link" aria-label="LinkedIn">
              <!-- LinkedIn icon -->
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          )}
        </div>
      </div>
    </section>

    <!-- Edit form (owner only) -->
    {isOwner && (
      <section class="edit-section" aria-labelledby="edit-heading">
        <h2 id="edit-heading" class="section-heading">プロフィールを編集</h2>
        <form id="profile-edit-form" class="edit-form" novalidate>
          <div class="form-group">
            <label for="edit-bio" class="form-label">自己紹介 (最大500文字)</label>
            <textarea
              id="edit-bio"
              name="bio"
              rows="3"
              maxlength="500"
              class="form-textarea"
              placeholder="自己紹介を入力…"
            >{userRow.bio ?? ""}</textarea>
          </div>
          <div class="form-group">
            <label for="edit-github-url" class="form-label">GitHub URL</label>
            <input
              id="edit-github-url"
              name="github_url"
              type="url"
              class="form-input"
              placeholder="https://github.com/yourname"
              value={userRow.github_url ?? ""}
            />
          </div>
          <div class="form-group">
            <label for="edit-x-url" class="form-label">X (Twitter) URL</label>
            <input
              id="edit-x-url"
              name="x_url"
              type="url"
              class="form-input"
              placeholder="https://x.com/yourname"
              value={userRow.x_url ?? ""}
            />
          </div>
          <div class="form-group">
            <label for="edit-linkedin-url" class="form-label">LinkedIn URL</label>
            <input
              id="edit-linkedin-url"
              name="linkedin_url"
              type="url"
              class="form-input"
              placeholder="https://linkedin.com/in/yourname"
              value={userRow.linkedin_url ?? ""}
            />
          </div>
          <div id="edit-error" class="edit-error" aria-live="polite" style="display:none;"></div>
          <div id="edit-success" class="edit-success" aria-live="polite" style="display:none;">保存しました。</div>
          <button type="submit" class="save-button" id="edit-save-btn">保存する</button>
        </form>
      </section>
    )}

    <!-- Recent notes -->
    <section class="notes-section" aria-labelledby="notes-heading">
      <h2 id="notes-heading" class="section-heading">最近のノート</h2>
      {recentNotes.length === 0 ? (
        <p class="empty-state">まだノートはありません。</p>
      ) : (
        <ul class="notes-list">
          {recentNotes.map((note) => {
            const articleTitle = articleTitleMap.get(note.article_slug) ?? note.article_slug;
            return (
              <li class="note-item">
                <div class="note-article-link-wrap">
                  <a href={`/articles/${note.article_slug}`} class="note-article-link">{articleTitle}</a>
                  <span class="note-date">{formatJpDate(note.created_at)}</span>
                </div>
                <p class="note-body">{note.body}</p>
              </li>
            );
          })}
        </ul>
      )}
    </section>

  </div>
</BaseLayout>

<style>
  .profile-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.5rem 0 3rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Profile card */
  .profile-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .profile-avatar-wrap {
    flex-shrink: 0;
  }

  .profile-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }

  .profile-avatar--fallback {
    background: var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-muted);
  }

  .profile-info {
    flex: 1;
    min-width: 0;
  }

  .profile-username {
    margin: 0 0 0.5rem;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .profile-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .contributor-badge {
    display: inline-block;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid;
    white-space: nowrap;
  }

  .profile-note-count,
  .profile-joined {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .profile-bio {
    margin: 0 0 0.75rem;
    color: var(--color-text);
    line-height: 1.6;
    font-size: 0.9375rem;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Social links */
  .profile-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .profile-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .profile-link:hover {
    color: var(--color-accent-hover);
    text-decoration: none;
  }

  /* Edit form */
  .section-heading {
    margin: 0 0 1rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .edit-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .edit-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-input,
  .form-textarea {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.625rem 0.75rem;
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.9375rem;
    line-height: 1.5;
    transition: border-color 0.2s, background-color 0.2s;
    width: 100%;
    box-sizing: border-box;
  }

  .form-textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    background: var(--color-surface);
    border-color: var(--color-accent);
  }

  .edit-error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    padding: 0.625rem 0.875rem;
    border-radius: 0.375rem;
    font-size: 0.9rem;
  }

  .edit-success {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    padding: 0.625rem 0.875rem;
    border-radius: 0.375rem;
    font-size: 0.9rem;
  }

  .save-button {
    align-self: flex-start;
    background: var(--color-accent);
    color: #fff;
    border: none;
    padding: 0.5rem 1.25rem;
    border-radius: 0.375rem;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  .save-button:hover {
    background: var(--color-accent-hover);
  }

  .save-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Notes section */
  .notes-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .notes-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .note-item {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1rem;
  }

  .note-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .note-article-link-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.375rem;
  }

  .note-article-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.15s;
  }

  .note-article-link:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  .note-date {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .note-body {
    margin: 0;
    color: var(--color-text);
    font-size: 0.9375rem;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .empty-state {
    color: var(--color-muted);
    font-style: italic;
    margin: 0;
  }

  @media (max-width: 600px) {
    .profile-page {
      padding: 1rem 0 2rem;
    }

    .profile-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1.25rem;
    }

    .profile-links {
      justify-content: center;
    }

    .profile-meta {
      justify-content: center;
    }
  }
</style>

<script>
  // Edit form — client-side PATCH submit.
  // Only rendered when the viewer is the profile owner (isOwner guard in template).
  const form = document.getElementById("profile-edit-form") as HTMLFormElement | null;

  if (form) {
    const saveBtn    = document.getElementById("edit-save-btn")  as HTMLButtonElement;
    const errorBox   = document.getElementById("edit-error")     as HTMLDivElement;
    const successBox = document.getElementById("edit-success")   as HTMLDivElement;

    function showError(msg: string): void {
      errorBox.textContent = msg;
      errorBox.style.display = "block";
      successBox.style.display = "none";
    }

    function showSuccess(): void {
      successBox.style.display = "block";
      errorBox.style.display = "none";
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      errorBox.style.display = "none";
      successBox.style.display = "none";
      saveBtn.disabled = true;
      saveBtn.textContent = "保存中…";

      const data = new FormData(form);

      const body: Record<string, string | null> = {
        bio:          (data.get("bio")          as string).trim() || null,
        github_url:   (data.get("github_url")   as string).trim() || null,
        x_url:        (data.get("x_url")        as string).trim() || null,
        linkedin_url: (data.get("linkedin_url") as string).trim() || null,
      };

      try {
        const res = await fetch("/api/profile", {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });

        if (!res.ok) {
          const err = await res.json() as { error?: string };
          showError(err.error ?? "保存に失敗しました。");
        } else {
          showSuccess();
        }
      } catch {
        showError("ネットワークエラーが発生しました。");
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = "保存する";
      }
    });
  }
</script>
