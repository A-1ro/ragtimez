---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getTrustLabel, getTrustColor } from "../../../constants/trustLevels";
import { formatDate } from "../../../utils/date";
import { computeArticleQualityFromData } from "../../../lib/quality";
import { getCounterpartArticleId } from "../../../lib/i18n";
import { env } from "cloudflare:workers";

export const prerender = false;

const { id } = Astro.params;
const lang = "en";

const allArticles = await getCollection("articles");
const article = allArticles.find((a) => a.id === id && a.data.lang === "en");

if (!article) {
  return Astro.redirect("/404");
}

const { Content } = await render(article);

const trustColor = getTrustColor(article.data.trustLevel);
const user = Astro.locals.user ?? null;

let noteCounts = { supplementCount: 0, correctionCount: 0 };
try {
  if (env.DB) {
    type NoteTypeRow = { note_type: string; cnt: number };
    const result = await env.DB.prepare(
      "SELECT note_type, COUNT(*) AS cnt FROM notes WHERE article_slug = ? GROUP BY note_type"
    )
      .bind(article.id)
      .all<NoteTypeRow>();
    for (const row of result.results ?? []) {
      if (row.note_type === "correction") {
        noteCounts.correctionCount = row.cnt;
      } else {
        noteCounts.supplementCount = row.cnt;
      }
    }
  }
} catch {
  // Non-fatal: DB unavailable in local dev
}

const quality = computeArticleQualityFromData(article.data, noteCounts);

const gradeColor: Record<string, string> = {
  A: "#22c55e",
  B: "#3d8ef5",
  C: "#f59e0b",
  D: "#ef4444",
};
const qualityColor = gradeColor[quality.grade] ?? "#6b7db3";

const notesAdjustmentDisplay =
  quality.breakdown.notesAdjustment > 0
    ? `+${quality.breakdown.notesAdjustment}`
    : String(quality.breakdown.notesAdjustment);

const qualityTooltip = [
  `Score: ${quality.score}/100`,
  `Sources: +${quality.breakdown.sources}`,
  `Official source ratio: +${quality.breakdown.officialRatio}`,
  `Trust level: +${quality.breakdown.trustLevel}`,
  `Community notes adjustment: ${notesAdjustmentDisplay}`,
].join(" | ");

// Resolve the counterpart Japanese article, if it exists.
// ja article ID is the en ID with ".en" removed (e.g. "2026-04-10.en" → "2026-04-10")
const counterpartId = getCounterpartArticleId(article.id, "en");
const counterpart = allArticles.find(
  (a) => a.id === counterpartId && a.data.lang === "ja"
);
const alternateLangHref: string | null = counterpart
  ? `/articles/${counterpart.id}`
  : null;
---

<BaseLayout
  title={`${article.data.title} | RAGtimeZ`}
  description={article.data.summary}
  ogType="article"
  lang="en"
  alternateLangHref={alternateLangHref}
>
  <article class="article">
    <header class="article-header">
      <a href="/en" class="back-link">← Back to list</a>
      <div class="article-meta">
        <time datetime={article.data.date.toISOString()} class="article-date">
          {formatDate(article.data.date, lang)}
        </time>
        <span
          class="trust-badge"
          style={`background-color: ${trustColor}22; color: ${trustColor}; border-color: ${trustColor}44;`}
        >
          {getTrustLabel(article.data.trustLevel, lang)}
        </span>
        <details class="quality-details">
          <summary
            class="trust-badge quality-badge"
            style={`background-color: ${qualityColor}22; color: ${qualityColor}; border-color: ${qualityColor}44; cursor: pointer; list-style: none;`}
            title={qualityTooltip}
          >
            Quality {quality.grade} <span class="quality-score-num">{quality.score}</span>
          </summary>
          <div class="quality-breakdown">
            <dl class="breakdown-list">
              <div class="breakdown-row">
                <dt>Sources</dt>
                <dd>+{quality.breakdown.sources}</dd>
              </div>
              <div class="breakdown-row">
                <dt>Official source ratio</dt>
                <dd>+{quality.breakdown.officialRatio}</dd>
              </div>
              <div class="breakdown-row">
                <dt>Trust level</dt>
                <dd>+{quality.breakdown.trustLevel}</dd>
              </div>
              <div class="breakdown-row">
                <dt>Community notes adjustment</dt>
                <dd>{notesAdjustmentDisplay}</dd>
              </div>
              <div class="breakdown-row breakdown-total">
                <dt>Total</dt>
                <dd>{quality.score} / 100</dd>
              </div>
            </dl>
          </div>
        </details>
      </div>
      <h1 class="article-title">{article.data.title}</h1>
      <p class="article-summary">{article.data.summary}</p>
      {article.data.tags.length > 0 && (
        <ul class="tag-list" aria-label="Tags">
          {article.data.tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )}
    </header>

    <div class="article-body prose">
      <Content />
    </div>

    {article.data.sources.length > 0 && (
      <aside class="sources">
        <h2 class="sources-heading">Sources</h2>
        <ul class="sources-list">
          {article.data.sources.map((source) => (
            <li class="source-item">
              <a href={source.url} target="_blank" rel="noopener noreferrer" class="source-link">
                {source.title ?? source.url}
              </a>
              {source.type && (
                <span class="source-type">{source.type}</span>
              )}
            </li>
          ))}
        </ul>
      </aside>
    )}

    <section class="community-notes" data-article-id={article.id} data-current-github-id={user?.githubId ?? ""}>
      <h2 class="notes-heading">Community Notes</h2>

      <div class="notes-controls">
        <label for="notes-sort" class="sort-label">Sort by:</label>
        <select id="notes-sort" class="sort-select">
          <option value="new">Newest</option>
          <option value="helpful">Most helpful</option>
        </select>
      </div>

      <div id="notes-list" class="notes-list" aria-live="polite" aria-label="Community notes list">
        <div class="loading-state">Loading…</div>
      </div>

      {user ? (
        <div class="note-form-container">
          <div class="form-header">
            <img
              src={user.avatarUrl}
              alt=""
              class="form-avatar"
            />
            <span class="form-username">{user.login}</span>
          </div>
          <form id="note-form" class="note-form">
            <textarea
              id="note-textarea"
              name="body"
              placeholder="Add a note about this article…"
              rows="3"
              maxlength="1000"
              required
            ></textarea>
            <div class="note-type-selector">
              <label class="note-type-label">
                <input type="radio" name="note_type" value="supplement" checked />
                <span class="note-type-text">💡 Supplement</span>
              </label>
              <label class="note-type-label">
                <input type="radio" name="note_type" value="correction" />
                <span class="note-type-text">⚠️ Correction</span>
              </label>
            </div>
            <div class="form-footer">
              <span id="char-count" class="char-count">0 / 1000</span>
              <button type="submit" class="submit-button">Post</button>
            </div>
          </form>
        </div>
      ) : (
        <div class="login-prompt">
          <p>Sign in with GitHub to add a note.</p>
          <a href={`/api/auth/login?redirect=${encodeURIComponent(Astro.url.pathname)}`} class="login-button">Login with GitHub</a>
        </div>
      )}
    </section>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.5rem 0 3rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }
  .back-link:hover {
    color: var(--color-accent-hover);
    text-decoration: none;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .article-date {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .trust-badge {
    display: inline-block;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid;
    white-space: nowrap;
  }

  .quality-details {
    position: relative;
    display: inline-block;
  }

  .quality-badge::-webkit-details-marker {
    display: none;
  }

  .quality-score-num {
    font-variant-numeric: tabular-nums;
    opacity: 0.85;
  }

  .quality-breakdown {
    position: absolute;
    top: calc(100% + 0.4rem);
    left: 0;
    z-index: 20;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    min-width: 220px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    font-size: 0.8125rem;
  }

  /* On mobile, anchor the popup to the right edge so it stays within the viewport */
  @media (max-width: 480px) {
    .quality-breakdown {
      left: auto;
      right: 0;
      min-width: 0;
      width: max-content;
      max-width: calc(100vw - 2rem);
    }
  }

  .breakdown-list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .breakdown-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-muted);
  }

  .breakdown-row dt {
    font-weight: 400;
  }

  .breakdown-row dd {
    margin: 0;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    color: var(--color-text);
  }

  .breakdown-total {
    margin-top: 0.4rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .breakdown-total dt,
  .breakdown-total dd {
    color: var(--color-text);
    font-weight: 700;
  }

  .article-title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .article-summary {
    margin: 0 0 1rem;
    font-size: 1.0625rem;
    color: var(--color-muted);
    line-height: 1.6;
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
  }

  .tag-list {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    background: var(--color-border);
    color: var(--color-muted);
    padding: 0.15em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
  }

  .article-body.prose {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
    margin-bottom: 2rem;
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 1.5rem 0 0.5rem;
    color: var(--color-text);
  }

  .prose :global(p) {
    margin: 0 0 1rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.375rem;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .prose :global(a) {
    color: var(--color-accent);
  }
  .prose :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .prose :global(code) {
    background: var(--color-border);
    padding: 0.1em 0.35em;
    border-radius: 0.25em;
    font-size: 0.875em;
    font-family: "Fira Code", "Cascadia Code", Consolas, monospace;
  }

  .prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-border);
    margin: 0 0 1rem;
    padding-left: 1rem;
    color: var(--color-muted);
  }

  /* Admin annotation (:::admin-note directive) */
  .prose :global(.admin-note) {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    background: rgba(249, 158, 11, 0.06);
    border: 1px solid rgba(249, 158, 11, 0.2);
    border-left: 4px solid var(--color-amber, #d97706);
    border-radius: 0.5rem;
  }

  .prose :global(.admin-note-header) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-amber, #d97706);
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .prose :global(.admin-note-header)::before {
    content: "\270F\FE0F";
  }

  .prose :global(.admin-note-body) {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .prose :global(.admin-note-body p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(.admin-note-author) {
    margin-top: 0.5rem;
    text-align: right;
    font-size: 0.8125rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .sources {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
  }

  .sources-heading {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .sources-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .source-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .source-link {
    font-size: 0.9375rem;
    word-break: break-all;
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 3px;
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .source-link:hover {
    color: var(--color-accent-soft);
    text-decoration-color: var(--color-accent-soft);
  }

  .source-type {
    font-size: 0.75rem;
    color: var(--color-muted);
    background: var(--color-border);
    padding: 0.1em 0.5em;
    border-radius: 999px;
    text-transform: capitalize;
  }

  .community-notes {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .notes-heading {
    margin: 0 0 1rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .notes-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .sort-label {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .sort-select {
    font-size: 0.8125rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    color: var(--color-text);
    padding: 0.2em 0.5em;
    cursor: pointer;
  }

  .sort-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
    min-height: 60px;
  }

  .loading-state,
  .empty-state {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--color-muted);
    font-style: italic;
  }

  :global(.note-item) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  :global(.note-avatar) {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
  }

  :global(.note-content) {
    flex: 1;
    min-width: 0;
  }

  :global(.note-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  :global(.note-meta) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  :global(.note-username) {
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }

  :global(.note-username:hover) {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  :global(.contributor-badge) {
    display: inline-block;
    padding: 0.15em 0.5em;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    border: 1px solid;
    white-space: nowrap;
    vertical-align: middle;
  }

  :global(.note-date) {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  :global(.note-delete-btn) {
    background: none;
    border: none;
    padding: 0.375rem;
    color: var(--color-muted);
    cursor: pointer;
    border-radius: 0.25rem;
    transition: background 0.15s ease, color 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0.5;
  }

  :global(.note-item:hover .note-delete-btn) {
    opacity: 1;
  }

  :global(.note-delete-btn:hover) {
    background: rgba(239, 68, 68, 0.12);
    color: #ef4444;
  }

  :global(.note-actions) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  :global(.helpful-btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.2em 0.65em;
    font-size: 0.8125rem;
    color: var(--color-muted);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    line-height: 1.4;
  }

  :global(.helpful-btn:hover) {
    background: var(--color-border);
    color: var(--color-text);
  }

  :global(.helpful-btn.voted) {
    background: var(--color-accent)22;
    border-color: var(--color-accent)44;
    color: var(--color-accent);
  }

  :global(.helpful-btn.voted:hover) {
    background: var(--color-accent)33;
  }

  :global(.helpful-btn svg) {
    flex-shrink: 0;
  }

  :global(.note-body) {
    color: var(--color-text);
    line-height: 1.6;
    word-wrap: break-word;
    white-space: pre-wrap;
  }

  .note-form-container {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
  }

  .form-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .form-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
  }

  .form-username {
    font-weight: 600;
    color: var(--color-text);
  }

  .note-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .note-form textarea {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.75rem;
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.9375rem;
    line-height: 1.5;
    resize: vertical;
    min-height: 100px;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .note-form textarea:focus {
    outline: none;
    background: var(--color-surface);
    border-color: var(--color-accent);
  }

  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .char-count {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .submit-button {
    background: var(--color-accent);
    color: #fff;
    border: none;
    padding: 0.5rem 1.25rem;
    border-radius: 0.375rem;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .submit-button:hover {
    background: var(--color-accent-hover);
  }

  .submit-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .submit-button.loading {
    opacity: 0.7;
    pointer-events: none;
  }

  .login-prompt {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1.5rem;
    text-align: center;
  }

  .login-prompt p {
    margin: 0 0 1rem;
    color: var(--color-muted);
  }

  .login-button {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.625rem 1.5rem;
    border-radius: 0.375rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .login-button:hover {
    background: var(--color-accent-hover);
  }

  /* Note type radio selector */
  .note-type-selector {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .note-type-label {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .note-type-label input[type="radio"] {
    accent-color: var(--color-accent, #3d8ef5);
  }

  /* Note type badge (rendered inside each note item by JS) */
  :global(.note-type-badge) {
    display: inline-block;
    padding: 0.1em 0.45em;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    white-space: nowrap;
  }

  :global(.note-type-badge.supplement) {
    background-color: #22c55e22;
    color: #22c55e;
    border: 1px solid #22c55e44;
  }

  :global(.note-type-badge.correction) {
    background-color: #f59e0b22;
    color: #f59e0b;
    border: 1px solid #f59e0b44;
  }

  @media (max-width: 600px) {
    .article {
      padding: 1rem 0 2rem;
    }
    .article-title {
      font-size: 1.375rem;
    }
    .sources {
      padding: 1rem;
    }

    .community-notes {
      margin-top: 2rem;
      padding-top: 1.5rem;
    }

    .notes-heading {
      font-size: 1.125rem;
      margin-bottom: 1rem;
    }

    :global(.note-item) {
      padding: 0.75rem;
      gap: 0.5rem;
    }

    :global(.note-avatar) {
      width: 32px;
      height: 32px;
    }

    :global(.note-meta) {
      flex: 1;
      min-width: 0;
    }

    .note-form-container {
      padding: 0.75rem;
    }

    .form-header {
      margin-bottom: 0.75rem;
    }

    .form-footer {
      flex-direction: column;
      align-items: stretch;
    }

    .char-count {
      text-align: right;
    }

    .submit-button {
      width: 100%;
    }

    .login-prompt {
      padding: 1rem;
    }

    .login-button {
      display: block;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      padding: 0.75rem;
    }
  }
</style>

<script>
  // Types for community notes
  interface Note {
    id: string;
    article_slug: string;
    author_github_id: string;
    author_username: string;
    author_avatar: string | null;
    body: string;
    created_at: string;
    updated_at: string;
    /** Total notes posted by this author — used to render contributor badges. */
    author_note_count: number;
    /** Number of "helpful" votes this note has received. */
    helpful_count: number;
    /** Whether the currently authenticated viewer has voted this note as helpful. */
    viewer_has_voted: boolean;
    /** Note classification: supplementary information or a correction. */
    note_type: string;
  }

  // ---------------------------------------------------------------------------
  // Contributor rank logic — inlined for browser execution (kept in sync with
  // src/lib/contributorBadge.ts). Rules: 0→none, 1-4→bronze, 5-19→silver, 20+→gold
  // ---------------------------------------------------------------------------
  type ContributorRank = "none" | "bronze" | "silver" | "gold";

  function getContributorRank(noteCount: number): ContributorRank {
    if (noteCount >= 20) return "gold";
    if (noteCount >= 5)  return "silver";
    if (noteCount >= 1)  return "bronze";
    return "none";
  }

  interface BadgeInfo { label: string; color: string }

  function getContributorBadgeInfo(noteCount: number): BadgeInfo | null {
    const rank = getContributorRank(noteCount);
    const map: Record<Exclude<ContributorRank, "none">, BadgeInfo> = {
      gold:   { label: "Contributor (Gold)",   color: "#ffd700" },
      silver: { label: "Contributor (Silver)", color: "#c0c0c0" },
      bronze: { label: "Contributor (Bronze)", color: "#cd7f32" },
    };
    return rank === "none" ? null : map[rank];
  }

  // Get data attributes from the section
  const section = document.querySelector(".community-notes") as HTMLElement;
  const articleId = section?.getAttribute("data-article-id") ?? "";
  const currentGithubId = section?.getAttribute("data-current-github-id") ?? "";

  const notesList = document.getElementById("notes-list") as HTMLDivElement;
  const noteForm = document.getElementById("note-form") as HTMLFormElement;
  const noteTextarea = document.getElementById("note-textarea") as HTMLTextAreaElement;
  const charCount = document.getElementById("char-count") as HTMLSpanElement;
  const notesSort = document.getElementById("notes-sort") as HTMLSelectElement;

  // Format relative time in English with correct singular/plural
  // <60s → "just now", <60m → "N min(s) ago", <24h → "N hour(s) ago",
  // <7d → "N day(s) ago", else → localeDateString
  function formatRelativeTime(dateStr: string): string {
    const now = new Date();
    const date = new Date(dateStr);
    const seconds = Math.floor((now.getTime() - date.getTime()) / 1000);

    if (seconds < 60) return "just now";

    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return minutes === 1 ? "1 min ago" : `${minutes} mins ago`;

    const hours = Math.floor(seconds / 3600);
    if (hours < 24) return hours === 1 ? "1 hour ago" : `${hours} hours ago`;

    const days = Math.floor(seconds / 86400);
    if (days < 7) return days === 1 ? "1 day ago" : `${days} days ago`;

    return date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
  }

  // Simple HTML escape to prevent XSS
  function escapeHtml(text: string): string {
    const map: Record<string, string> = {
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#039;",
    };
    return text.replace(/[&<>"']/g, (char) => map[char]);
  }

  // Render a single note as a DOM element
  function renderNote(note: Note): HTMLElement {
    const div = document.createElement("div");
    div.className = "note-item";
    div.setAttribute("data-note-id", note.id);

    const avatarHtml =
      note.author_avatar && note.author_avatar.trim()
        ? `<img src="${escapeHtml(note.author_avatar)}" alt="${escapeHtml(note.author_username)}" class="note-avatar" width="36" height="36" />`
        : `<div class="note-avatar" style="background: var(--color-border); display: flex; align-items: center; justify-content: center; font-weight: 600;">?</div>`;

    const deleteButtonHtml =
      currentGithubId === note.author_github_id
        ? `<button type="button" class="note-delete-btn" data-note-id="${escapeHtml(note.id)}" aria-label="Delete note" title="Delete">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="3,6 5,6 21,6"/>
              <path d="M19,6l-1,14a2,2,0,0,1-2,2H8a2,2,0,0,1-2-2L5,6"/>
              <path d="M10,11v6"/><path d="M14,11v6"/>
              <path d="M9,6V4a1,1,0,0,1,1-1h4a1,1,0,0,1,1,1V6"/>
            </svg>
          </button>`
        : "";

    // Build contributor badge HTML (if the author has earned a rank).
    const badgeInfo = getContributorBadgeInfo(note.author_note_count);
    const badgeHtml = badgeInfo
      ? `<span class="contributor-badge" style="background-color:${badgeInfo.color}22;color:${badgeInfo.color};border-color:${badgeInfo.color}44;">${escapeHtml(badgeInfo.label)}</span>`
      : "";

    // Build note type badge HTML.
    const noteTypeBadgeHtml = note.note_type === "correction"
      ? `<span class="note-type-badge correction">⚠️ Correction</span>`
      : `<span class="note-type-badge supplement">💡 Supplement</span>`;

    // Helpful button — shown for all notes; requires login to actually vote.
    const votedClass = note.viewer_has_voted ? " voted" : "";
    // Filled thumb when voted, outline when not.
    const thumbSvg = note.viewer_has_voted
      ? `<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>`
      : `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>`;
    const helpfulBtnHtml = `
      <button type="button" class="helpful-btn${votedClass}" data-note-id="${escapeHtml(note.id)}" aria-label="Helpful" aria-pressed="${note.viewer_has_voted}">
        ${thumbSvg}
        <span class="helpful-count">${note.helpful_count}</span>
        Helpful
      </button>`;

    div.innerHTML = `
      ${avatarHtml}
      <div class="note-content">
        <div class="note-header">
          <div class="note-meta">
            <a href="/profile/${escapeHtml(note.author_username)}" class="note-username">${escapeHtml(note.author_username)}</a>
            ${noteTypeBadgeHtml}
            ${badgeHtml}
            <span class="note-date">${formatRelativeTime(note.created_at)}</span>
          </div>
          ${deleteButtonHtml}
        </div>
        <div class="note-body">${escapeHtml(note.body)}</div>
        <div class="note-actions">${helpfulBtnHtml}</div>
      </div>
    `;

    // Attach delete handler
    const deleteBtn = div.querySelector(".note-delete-btn") as HTMLButtonElement;
    if (deleteBtn) {
      deleteBtn.addEventListener("click", async () => {
        await deleteNote(note.id, div);
      });
    }

    // Attach helpful vote handler
    const helpfulBtn = div.querySelector(".helpful-btn") as HTMLButtonElement;
    if (helpfulBtn) {
      helpfulBtn.addEventListener("click", async () => {
        await toggleHelpful(note.id, helpfulBtn);
      });
    }

    return div;
  }

  // Load and render notes from the API.
  // Appends ?lang=en so error messages come back in English.
  async function loadNotes(sort: string = "new"): Promise<void> {
    try {
      const url = `/api/notes?article=${encodeURIComponent(articleId)}&sort=${encodeURIComponent(sort)}&lang=en`;
      const response = await fetch(url);

      if (!response.ok) {
        throw new Error(`Failed to load notes: ${response.status}`);
      }

      const data = (await response.json()) as { notes: Note[] };
      const notes = data.notes || [];

      // Preserve scroll position so the viewport doesn't jump when re-rendering
      // after a sort change.
      const scrollTop = notesList.scrollTop;
      notesList.innerHTML = "";

      if (notes.length === 0) {
        const emptyDiv = document.createElement("div");
        emptyDiv.className = "empty-state";
        emptyDiv.textContent = "No notes yet. Be the first to add one!";
        notesList.appendChild(emptyDiv);
      } else {
        // Server already sorted — render in returned order.
        notes.forEach((note) => {
          notesList.appendChild(renderNote(note));
        });
      }
      notesList.scrollTop = scrollTop;
    } catch (error) {
      console.error("Error loading notes:", error);
      notesList.innerHTML = '<div class="empty-state">Failed to load notes.</div>';
    }
  }

  // Toggle helpful vote for a note.
  async function toggleHelpful(noteId: string, btn: HTMLButtonElement): Promise<void> {
    // Require login
    if (!currentGithubId) {
      alert("Sign in required. Please log in with GitHub.");
      return;
    }

    // Prevent double-clicks while the request is in flight.
    btn.disabled = true;

    const isVoted = btn.classList.contains("voted");
    const method = isVoted ? "DELETE" : "POST";

    try {
      const response = await fetch(
        `/api/notes/${encodeURIComponent(noteId)}/helpful?lang=en`,
        { method }
      );

      if (!response.ok) {
        throw new Error(`Failed to ${method} helpful vote: ${response.status}`);
      }

      const data = (await response.json()) as {
        helpful_count: number;
        viewer_has_voted: boolean;
      };

      // Update count display
      const countSpan = btn.querySelector(".helpful-count") as HTMLSpanElement;
      if (countSpan) {
        countSpan.textContent = String(data.helpful_count);
      }

      // Toggle voted state and update icon
      const filledSvg = `<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>`;
      const outlineSvg = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>`;

      if (data.viewer_has_voted) {
        btn.classList.add("voted");
        btn.setAttribute("aria-pressed", "true");
        const svgEl = btn.querySelector("svg");
        if (svgEl) svgEl.outerHTML = filledSvg;
      } else {
        btn.classList.remove("voted");
        btn.setAttribute("aria-pressed", "false");
        const svgEl = btn.querySelector("svg");
        if (svgEl) svgEl.outerHTML = outlineSvg;
      }
    } catch (error) {
      console.error("Error toggling helpful vote:", error);
      alert("Failed to process vote.");
    } finally {
      btn.disabled = false;
    }
  }

  // Delete a note
  async function deleteNote(noteId: string, noteElement: HTMLElement): Promise<void> {
    if (!confirm("Delete this note?")) {
      return;
    }

    try {
      const response = await fetch(
        `/api/notes/${encodeURIComponent(noteId)}?lang=en`,
        { method: "DELETE" }
      );

      if (!response.ok) {
        throw new Error(`Failed to delete note: ${response.status}`);
      }

      // Remove from DOM with a smooth transition
      noteElement.style.opacity = "0";
      noteElement.style.transition = "opacity 0.2s ease";
      setTimeout(() => {
        noteElement.remove();

        // If no notes left, show empty state
        const remainingNotes = notesList.querySelectorAll(".note-item");
        if (remainingNotes.length === 0) {
          const emptyDiv = document.createElement("div");
          emptyDiv.className = "empty-state";
          emptyDiv.textContent = "No notes yet. Be the first to add one!";
          notesList.appendChild(emptyDiv);
        }
      }, 200);
    } catch (error) {
      console.error("Error deleting note:", error);
      alert("Failed to delete note.");
    }
  }

  // Character count update
  if (noteTextarea) {
    noteTextarea.addEventListener("input", () => {
      const length = noteTextarea.value.length;
      charCount.textContent = `${length} / 1000`;
    });
  }

  // Handle form submission
  if (noteForm) {
    noteForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const body = noteTextarea.value.trim();

      if (!body) {
        alert("Please enter a note.");
        return;
      }

      const submitBtn = noteForm.querySelector(".submit-button") as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.classList.add("loading");
      submitBtn.textContent = "Posting…";

      try {
        const noteType = (noteForm.querySelector('input[name="note_type"]:checked') as HTMLInputElement)?.value ?? "supplement";
        const response = await fetch("/api/notes?lang=en", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            article_slug: articleId,
            body,
            note_type: noteType,
          }),
        });

        if (!response.ok) {
          const error = await response.text();
          throw new Error(`Failed to post note: ${response.status} ${error}`);
        }

        const data = (await response.json()) as { note: Note };
        const newNote = data.note;

        // Clear the form
        noteTextarea.value = "";
        charCount.textContent = "0 / 1000";

        // Remove empty state if present
        const emptyState = notesList.querySelector(".empty-state");
        if (emptyState) {
          emptyState.remove();
        }

        // Add new note to the top of the list
        const noteElement = renderNote(newNote);
        noteElement.style.opacity = "0";
        noteElement.style.transition = "opacity 0.3s ease";
        notesList.insertBefore(noteElement, notesList.firstChild);

        // Trigger animation
        setTimeout(() => {
          noteElement.style.opacity = "1";
        }, 10);
      } catch (error) {
        console.error("Error posting note:", error);
        alert("Failed to post note.");
      } finally {
        submitBtn.disabled = false;
        submitBtn.classList.remove("loading");
        submitBtn.textContent = "Post";
      }
    });
  }

  // Re-fetch notes when sort order changes
  if (notesSort) {
    notesSort.addEventListener("change", () => {
      loadNotes(notesSort.value);
    });
  }

  // Load notes on page load
  loadNotes();
</script>
