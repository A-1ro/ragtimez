---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { trustLabelMap } from "../../constants/trustLevels";
import { formatDate } from "../../utils/date";
import { t } from "../../lib/i18n";

const lang = "en";
const allArticles = await getCollection("articles", ({ data }) => !data.draft && data.lang === "en");
const articles = allArticles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const today = new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric", weekday: "short" });
---

<BaseLayout title="RAGtimeZ" lang="en">
  <section class="edition-header">
    <div class="edition-meta">
      <span class="edition-date">{today}</span>
      <span class="edition-count">{articles.length} {t(lang, "articles")}</span>
    </div>
    <div class="edition-ornament">◆</div>
  </section>

  <section class="article-list" aria-label="Article list">
    {articles.length === 0 && (
      <p class="empty">{t(lang, "noArticles")}</p>
    )}
    {articles.map((article) => {
      const trust = trustLabelMap[article.data.trustLevel];
      return (
        <article class="card">
          <a href={`/en/articles/${article.id}`} class="card-link">
            <div class="card-top">
              <time datetime={article.data.date.toISOString()} class="card-date">
                {formatDate(article.data.date, lang)}
              </time>
              <span
                class="trust-badge"
                style={`background-color: ${trust.color}22; color: ${trust.color}; border-color: ${trust.color}44;`}
              >
                {trust.label}
              </span>
            </div>
            <h2 class="card-title">{article.data.title}</h2>
            <p class="card-summary">{article.data.summary}</p>
            {article.data.tags.length > 0 && (
              <ul class="tag-list" aria-label="Tags">
                {article.data.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            )}
          </a>
        </article>
      );
    })}
  </section>
</BaseLayout>

<style>
  .edition-header {
    text-align: center;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .edition-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-muted);
  }

  .edition-date {
    color: var(--color-text);
    font-weight: 600;
  }

  .edition-count {
    color: var(--color-muted);
  }

  .edition-ornament {
    font-size: 1rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-shadow: 0 0 10px rgba(61, 142, 245, 0.8);
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .empty {
    color: var(--color-muted);
    text-align: center;
    padding: 3rem 0;
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px rgba(61, 142, 245, 0.2), 0 8px 32px rgba(61, 142, 245, 0.15);
    transform: translateY(-1px);
  }

  .card-link {
    display: block;
    padding: 1.25rem 1.5rem;
    color: inherit;
    text-decoration: none;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .card-date {
    font-size: 0.8125rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .trust-badge {
    display: inline-block;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card-title {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text);
  }

  .card-summary {
    margin: 0 0 0.75rem;
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .tag-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    background: rgba(61, 142, 245, 0.1);
    color: var(--color-accent-soft);
    padding: 0.15em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
    border: 1px solid rgba(61, 142, 245, 0.25);
  }

  @media (max-width: 600px) {
    .edition-header {
      padding: 1.5rem 0;
      margin-bottom: 1.75rem;
    }

    .card-link {
      padding: 1rem;
    }

    .card-title {
      font-size: 1rem;
    }

    .card-top {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
