---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { trustLabelMap } from "../constants/trustLevels";
import { formatDate } from "../utils/date";
import { getBookmarks } from "../lib/bookmarks";
import { env } from "cloudflare:workers";
import { getLangFromPath, t } from "../lib/i18n";

// SSR: rendered per-request so we can gate on session
export const prerender = false;

const lang = getLangFromPath(Astro.url.pathname);
const user = Astro.locals.user;

// Redirect unauthenticated visitors to GitHub login
if (!user) {
  return Astro.redirect(
    `/api/auth/login?redirect=${encodeURIComponent("/bookmarks")}`
  );
}

// Fetch bookmarked slugs from D1. Gracefully return an empty list when the
// binding is unavailable (local Astro dev without wrangler bindings).
let bookmarkedSlugs: string[] = [];
if (env.DB) {
  try {
    const rows = await getBookmarks(env.DB, user.githubId);
    bookmarkedSlugs = rows.map((r) => r.article_slug);
  } catch {
    // Non-fatal: DB unavailable in local dev
  }
}

// Resolve article metadata from the content collection for each bookmarked slug.
// Slugs that no longer correspond to a published article are silently dropped.
const allArticles = await getCollection(
  "articles",
  ({ data }) => !data.draft
);

const bookmarkedArticles = bookmarkedSlugs
  .map((slug) => allArticles.find((a) => a.id === slug))
  .filter((a): a is NonNullable<typeof a> => a !== undefined);
---

<BaseLayout title={`${t(lang, "bookmarksPageTitle")} | RAGtimeZ`} lang={lang} alternateLangHref={null}>
  <section class="bookmarks-header">
    <h1 class="page-title">
      <svg class="page-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
      </svg>
      {t(lang, "bookmarksPageTitle")}
    </h1>
    <p class="page-subtitle">{bookmarkedArticles.length} {t(lang, "bookmarksCount")}</p>
  </section>

  {bookmarkedArticles.length === 0 ? (
    <div class="empty-state">
      <svg class="empty-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
      </svg>
      <p>{t(lang, "bookmarksEmpty")}</p>
      <a href="/" class="browse-link">{t(lang, "bookmarksBrowse")}</a>
    </div>
  ) : (
    <section class="article-list" aria-label={t(lang, "bookmarksArticleList")}>
      {bookmarkedArticles.map((article) => {
        const trust = trustLabelMap[article.data.trustLevel];
        return (
          <article class="card">
            <a href={`/articles/${article.id}`} class="card-link">
              <div class="card-top">
                <time datetime={article.data.date.toISOString()} class="card-date">
                  {formatDate(article.data.date)}
                </time>
                <span
                  class="trust-badge"
                  style={`background-color: ${trust.color}22; color: ${trust.color}; border-color: ${trust.color}44;`}
                >
                  {trust.label}
                </span>
              </div>
              <h2 class="card-title">{article.data.title}</h2>
              <p class="card-summary">{article.data.summary}</p>
              {article.data.tags.length > 0 && (
                <ul class="tag-list" aria-label="タグ">
                  {article.data.tags.map((tag) => (
                    <li class="tag">{tag}</li>
                  ))}
                </ul>
              )}
            </a>
          </article>
        );
      })}
    </section>
  )}
</BaseLayout>

<style>
  .bookmarks-header {
    padding: 2rem 0 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .page-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .page-icon {
    color: var(--color-accent-soft);
    flex-shrink: 0;
  }

  .page-subtitle {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-muted);
  }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 4rem 1rem;
    text-align: center;
    color: var(--color-muted);
  }

  .empty-icon {
    opacity: 0.3;
  }

  .empty-state p {
    margin: 0;
    font-size: 1rem;
  }

  .browse-link {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.5rem 1.25rem;
    border-radius: 0.375rem;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .browse-link:hover {
    background: var(--color-accent-hover);
    text-decoration: none;
    color: #fff;
  }

  /* Article cards — reuse index page patterns */
  .article-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px rgba(61, 142, 245, 0.2), 0 8px 32px rgba(61, 142, 245, 0.15);
    transform: translateY(-1px);
  }

  .card-link {
    display: block;
    padding: 1.25rem 1.5rem;
    color: inherit;
    text-decoration: none;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .card-date {
    font-size: 0.8125rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .trust-badge {
    display: inline-block;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card-title {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text);
  }

  .card-summary {
    margin: 0 0 0.75rem;
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .tag-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    background: rgba(61, 142, 245, 0.1);
    color: var(--color-accent-soft);
    padding: 0.15em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
    border: 1px solid rgba(61, 142, 245, 0.25);
  }

  @media (max-width: 600px) {
    .bookmarks-header {
      padding: 1.5rem 0 1rem;
      margin-bottom: 1.5rem;
    }

    .page-title {
      font-size: 1.375rem;
    }

    .card-link {
      padding: 1rem;
    }

    .card-title {
      font-size: 1rem;
    }

    .card-top {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
