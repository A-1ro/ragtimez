---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { trustLabelMap } from "../constants/trustLevels";
import { formatDate } from "../utils/date";

const allArticles = await getCollection("articles", ({ data }) => !data.draft);
const articles = allArticles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="AI Tech Daily">
  <section class="hero">
    <h1>AI Tech Daily</h1>
    <p class="hero-sub">
      AI-powered daily tech blog covering Azure / LLM / RAG / AI Agents
    </p>
  </section>

  <section class="article-list" aria-label="記事一覧">
    {articles.length === 0 && (
      <p class="empty">記事はまだありません。</p>
    )}
    {articles.map((article) => {
      const trust = trustLabelMap[article.data.trustLevel];
      return (
        <article class="card">
          <a href={`/articles/${article.id}`} class="card-link">
            <header class="card-header">
              <h2 class="card-title">{article.data.title}</h2>
              <span
                class="trust-badge"
                style={`background-color: ${trust.color}22; color: ${trust.color}; border-color: ${trust.color}44;`}
              >
                {trust.label}
              </span>
            </header>
            <p class="card-summary">{article.data.summary}</p>
            <footer class="card-footer">
              <time datetime={article.data.date.toISOString()} class="card-date">
                {formatDate(article.data.date)}
              </time>
              {article.data.tags.length > 0 && (
                <ul class="tag-list" aria-label="タグ">
                  {article.data.tags.map((tag) => (
                    <li class="tag">{tag}</li>
                  ))}
                </ul>
              )}
            </footer>
          </a>
        </article>
      );
    })}
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .hero h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }

  .hero-sub {
    margin: 0;
    color: var(--color-muted);
    font-size: 1rem;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .empty {
    color: var(--color-muted);
    text-align: center;
    padding: 3rem 0;
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent)22;
  }

  .card-link {
    display: block;
    padding: 1.25rem 1.5rem;
    color: inherit;
    text-decoration: none;
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .card-title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text);
    flex: 1;
    min-width: 0;
  }

  .trust-badge {
    display: inline-block;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.1em;
  }

  .card-summary {
    margin: 0 0 0.75rem;
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .card-footer {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .card-date {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .tag-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    background: var(--color-border);
    color: var(--color-muted);
    padding: 0.15em 0.6em;
    border-radius: 999px;
    font-size: 0.75rem;
  }

  @media (max-width: 600px) {
    .card-link {
      padding: 1rem;
    }
    .card-title {
      font-size: 1rem;
    }
  }
</style>
