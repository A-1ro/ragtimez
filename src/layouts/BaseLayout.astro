---
import NewsletterForm from "../components/NewsletterForm.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "AI-powered daily tech blog covering Azure / LLM / RAG / AI Agents",
  ogImage = "/og-default.png",
  ogType = "website",
  canonicalUrl = Astro.url.href,
} = Astro.props;

const siteName = "RAGtimeZ";
const user = Astro.locals.user;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/png" />

    <!-- OGP -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? Astro.url.origin).href} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? Astro.url.origin).href} />

    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RAGtimeZ RSS Feed"
      href={new URL("/rss.xml", Astro.site ?? Astro.url.origin).href}
    />

    <!-- Google Fonts: Playfair Display -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
      }

      :root {
        --color-bg: #080c1e;
        --color-surface: #0d1330;
        --color-border: #1b2554;
        --color-text: #e4ebff;
        --color-muted: #6b7db3;
        --color-accent: #3d8ef5;
        --color-accent-hover: #6aabff;
        --color-accent-soft: #93c5fd;
        --color-glow: rgba(61, 142, 245, 0.25);
        --color-amber: #d97706;
        --trust-official: #22c55e;
        --trust-blog: #f59e0b;
        --trust-speculative: #ef4444;
        --font-display: 'Playfair Display', Georgia, serif;
        --max-width: 900px;
        --spacing: 1.5rem;
        --gradient-azure: linear-gradient(135deg, #38bdf8 0%, #3d8ef5 100%);
      }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--color-bg);
        color: var(--color-text);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
        line-height: 1.7;
        font-size: 16px;
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
      }
      a:hover {
        color: var(--color-accent-hover);
        text-decoration: underline;
      }

      header {
        border-bottom: 1px solid var(--color-border);
        background: rgba(13, 19, 48, 0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 1px 30px rgba(61, 142, 245, 0.08);
      }

      /* Header top: brand name + RSS/auth */
      .header-top {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 1.25rem var(--spacing);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .nav-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .brand-link {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
      }
      .brand-link:hover {
        text-decoration: none;
        opacity: 0.85;
      }

      .brand-logo {
        height: 36px;
        width: auto;
        display: block;
      }

      .rss-link {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--color-muted);
        text-decoration: none;
        transition: color 0.2s;
      }
      .rss-link:hover {
        color: #f97316;
        text-decoration: none;
      }

      .nav-auth {
        display: flex;
        align-items: center;
      }

      .login-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-accent-soft);
        background: rgba(61, 142, 245, 0.08);
        border: 1px solid rgba(61, 142, 245, 0.3);
        border-radius: 0.5rem;
        padding: 0.35em 0.9em;
        transition: background 0.2s, border-color 0.2s, color 0.2s, box-shadow 0.2s;
        text-decoration: none;
      }
      .login-btn:hover {
        background: var(--color-accent);
        border-color: var(--color-accent);
        color: #fff;
        box-shadow: 0 0 16px rgba(61, 142, 245, 0.4);
        text-decoration: none;
      }

      .user-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .user-avatar {
        border-radius: 50%;
        display: block;
        flex-shrink: 0;
      }

      .user-login {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-text);
      }

      .logout-form {
        margin: 0;
        padding: 0;
      }

      .logout-btn {
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--color-muted);
        background: none;
        border: 1px solid var(--color-border);
        border-radius: 0.5rem;
        padding: 0.3em 0.75em;
        cursor: pointer;
        transition: color 0.2s, border-color 0.2s;
      }
      .logout-btn:hover {
        color: var(--color-text);
        border-color: var(--color-muted);
      }


      main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: var(--spacing);
      }

      footer {
        border-top: 1px solid var(--color-border);
        padding: 2rem var(--spacing);
        color: var(--color-muted);
        font-size: 0.875rem;
        margin-top: 4rem;
      }

      .footer-content {
        max-width: var(--max-width);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        align-items: start;
      }

      .footer-brand {
        height: 28px;
        width: auto;
        display: block;
        margin: 0 0 0.5rem;
        opacity: 1;
      }

      .footer-copyright {
        font-size: 0.8125rem;
        margin: 0;
      }

      .footer-info {
        text-align: right;
      }

      .newsletter-cta {
        border-top: 1px solid var(--color-border);
        background:
          radial-gradient(ellipse at top, rgba(61, 142, 245, 0.08), transparent 60%),
          var(--color-surface);
        padding: 4rem var(--spacing) 4.5rem;
        margin-top: 6rem;
      }

      .newsletter-cta-inner {
        max-width: 560px;
        margin: 0 auto;
        text-align: center;
      }

      .newsletter-cta h2 {
        margin: 0 0 0.75rem;
        font-size: clamp(1.5rem, 4vw, 1.875rem);
        font-weight: 800;
        line-height: 1.3;
        letter-spacing: -0.02em;
        color: var(--color-text);
      }

      .newsletter-cta p {
        margin: 0 0 1.75rem;
        font-size: 0.9375rem;
        color: var(--color-muted);
        line-height: 1.6;
      }

      @media (max-width: 600px) {
        .newsletter-cta {
          padding: 3rem var(--spacing) 3.25rem;
          margin-top: 4rem;
        }
        .newsletter-cta h2 {
          font-size: 1.5rem;
        }
      }

      @media (max-width: 600px) {
        :root {
          --spacing: 1rem;
        }
        html, body {
          font-size: 15px;
        }
        .brand-logo {
          height: 28px;
        }
.footer-content {
          grid-template-columns: 1fr;
          text-align: left;
        }
        .footer-info {
          text-align: left;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-top">
        <div class="nav-left">
          <a href="/" class="brand-link">
            <img src="/logo.png" alt="RAGtimeZ" class="brand-logo" />
          </a>
          <a href="/rss.xml" class="rss-link" aria-label="RSSフィード">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20 4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
            RSS
          </a>
        </div>
        <div class="nav-auth">
          {user ? (
            <div class="user-info">
              <img
                src={user.avatarUrl}
                alt={user.login}
                class="user-avatar"
                width="28"
                height="28"
              />
              <span class="user-login">{user.login}</span>
              <form method="POST" action="/api/auth/logout" class="logout-form">
                <button type="submit" class="logout-btn">ログアウト</button>
              </form>
            </div>
          ) : (
            <a href="/api/auth/login" class="login-btn">GitHubでログイン</a>
          )}
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <section class="newsletter-cta" aria-labelledby="newsletter-heading">
      <div class="newsletter-cta-inner">
        <h2 id="newsletter-heading">最新のAI動向を毎朝お届け</h2>
        <p>Azure / LLM / RAG / AI Agents の注目記事を、毎日要約してメールでお届けします。いつでも解除できます。</p>
        <NewsletterForm />
      </div>
    </section>
    <footer>
      <div class="footer-content">
        <div>
          <img src="/logo.png" alt="RAGtimeZ" class="footer-brand" />
          <p class="footer-copyright">&copy; {new Date().getFullYear()} RAGtimeZ. All rights reserved.</p>
        </div>
        <div class="footer-info">
          <p>AI-powered daily tech blog covering Azure, LLM, RAG, and AI Agents</p>
        </div>
      </div>
    </footer>
  </body>
</html>
