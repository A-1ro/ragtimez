---
import { localizePath, type Lang } from "../lib/i18n";

interface Props {
  currentLang: Lang;
  /**
   * Explicit href for the alternate-language link.
   * - undefined (default): falls back to localizePath(pathname, otherLang)
   * - string: uses the provided value as the href
   * - null: renders nothing (counterpart article does not exist)
   */
  alternateHref?: string | null;
}

const { currentLang, alternateHref } = Astro.props;

// null means the counterpart page does not exist; render nothing.
if (alternateHref === null) {
  return;
}

const otherLang = currentLang === "ja" ? "en" : "ja";
const otherLangPath = alternateHref ?? localizePath(Astro.url.pathname, otherLang);
---

<div class="lang-switcher">
  {currentLang === "ja" ? (
    <a href={otherLangPath} class="lang-link" aria-label="Switch to English">
      EN
    </a>
  ) : (
    <a href={otherLangPath} class="lang-link" aria-label="日本語に切り替える">
      JA
    </a>
  )}
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
  }

  .lang-link {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.3em 0.6em;
    transition: color 0.2s;
  }

  .lang-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
